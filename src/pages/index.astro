---
import Translation from "../components/Translation.astro";
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Astro</title>
	</head>
	<body>
		<h1>Astro</h1>
		<div class="translate" id="affichage">DEFAULT_TEXT</div>
	</body>
	<footer>
		<Translation />
	</footer>
</html>

<script>
	async function GetDatas(limit=20, offset=0) {
		limit = Math.min(Math.max(limit, 0), 100);
		offset = Math.min(Math.max(offset, 0), 10_000);
		const response = await fetch(`https://opendata.paris.fr/api/explore/v2.1/catalog/datasets/velib-disponibilite-en-temps-reel/records?limit=${limit}&offset=${offset}`);
		const data = await response.json();
		return data;
	}

	async function GetDatasFromStation(stationIndex: number) {
		return GetDatas(1, stationIndex).then(datas => {
			console.log(datas);
			if (datas.total_count >= 1) return datas.results[0];
			else return null;
		});
	}

	async function AfficheDatas() {
		const AFFICHAGE = document.getElementById("affichage");
		if (!AFFICHAGE) return;

		GetDatasFromStation(9999).then(data => {
			if (!data) return;
			AFFICHAGE.innerHTML = data.name;
		})
	}

	AfficheDatas()
</script>