		<meta name="generator" content={Astro.generator} />
		<title>Astro</title>
	</head>
	<body>
		<h1>Astro</h1>
		<div id="affichage">DEFAULT_TEXT</div>
	</body>
</html>

<script>
	async function GetDatas() {
		const response = await fetch("https://opendata.paris.fr/api/explore/v2.1/catalog/datasets/velib-disponibilite-en-temps-reel/records?limit=100");
		const data = await response.json();
		return data;
	}

	async function GetData(num: number) {
		return GetDatas().then(datas => {
			console.log(datas);
			if (0 <= num && num < datas.total_count) return datas.results[num];
			else return null;
		});
	}

	async function AfficheDatas() {
		const AFFICHAGE = document.getElementById("affichage");
		if (!AFFICHAGE) return;

		GetData(0).then(data => {
			console.log(data);
			AFFICHAGE.innerHTML = data.name;
		})
	}

	AfficheDatas()
</script>