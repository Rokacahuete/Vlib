---
const { dept } = Astro.props;
---

<div class="arrondissement centered" id={dept}>
    { dept }
</div>

<style>
    .arrondissement {
        border: 2px solid var(--border-color);
        border-radius: 10px;

        justify-content: center;
        width: 50px;
        height: 50px;
    }
</style>